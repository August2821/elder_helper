<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10sp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="로고"
        android:textSize="50sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <android.widget.Button
            android:id="@+id/button1"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/phoneinsert"
            android:padding="13dp"
            android:textSize="18sp"
            android:text="휴대폰 사용법"
            android:textColor="#FFFFFF" />

        <android.widget.Button
            android:id="@+id/button2"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/mapinsert"
            android:padding="15dp"
            android:textSize="18sp"
            android:text="지도 사용법"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">


        <android.widget.Button
            android:id="@+id/button3"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/skinsert"
            android:padding="10dp"
            android:textSize="18sp"
            android:text="키오스크 사용법"
            android:textColor="#FFFFFF" />

        <android.widget.Button
            android:id="@+id/button4"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/deliveryinsert"
            android:padding="10dp"
            android:textSize="18sp"
            android:text="배달앱 사용법"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">


        <android.widget.Button
            android:id="@+id/button5"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/gameinsert"
            android:padding="15dp"
            android:textSize="18sp"
            android:text="치매예방 기억력게임"
            android:textColor="#FFFFFF" />

        <android.widget.Button
            android:id="@+id/button6"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:drawableTop="@drawable/postinsert"
            android:padding="15dp"
            android:textSize="18sp"
            android:text="건의함"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>